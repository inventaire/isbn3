{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug parse test",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/mocha/bin/_mocha",
      "args": [
        "test/parse.js"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Debug CLI (isbn data)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/isbn",
      "args": [
        "9781781682135",
        "data"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}